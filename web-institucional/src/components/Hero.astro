---
// src/components/Hero.astro
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden px-4 sm:px-6 lg:px-8">
  
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] sm:w-[500px] h-[300px] rounded-full bg-institucional-acento/10 blur-[80px] sm:blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto text-center space-y-8 z-10">
    
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-institucional-superficie border border-institucional-componente text-slate-300 shadow-inner animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-institucional-acento animate-pulse"></span>
      Proceso de Admisión 2026 Abierto
    </div>

    <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-white via-slate-200 to-slate-500 leading-tight">
      Forjando el Futuro de la <br class="hidden sm:inline" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-institucional-acento to-cyan-200">
        Innovación Tecnológica
      </span>
    </h1>

    <p class="max-w-2xl mx-auto text-base sm:text-xl text-slate-400 font-light leading-relaxed">
      Formación profesional de alto nivel orientada al desarrollo de software, seguridad digital y las competencias tecnológicas más demandadas en el mercado global.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
      <a
        href="/admision"
        class="w-full sm:w-auto px-8 py-3 rounded-lg bg-institucional-acento text-slate-950 font-semibold shadow-lg shadow-institucional-acento/20 hover:bg-cyan-400 transition-all duration-300 text-center transform hover:-translate-y-0.5"
      >
        Postular Ahora
      </a>
      <a
        href="/carreras"
        class="w-full sm:w-auto px-8 py-3 rounded-lg bg-institucional-superficie text-slate-200 font-medium border border-institucional-componente hover:bg-institucional-componente hover:text-white transition-all duration-300 text-center transform hover:-translate-y-0.5"
      >
        Explorar Carreras
      </a>
    </div>

  </div>
</section>