---
// src/layouts/LayoutBase.astro
import '../styles/global.css';
import Navbar from '../components/Navbar'; // 👈 Importamos el componente de React

interface Props {
	titulo: string;
	descripcion?: string;
}

const { titulo, descripcion = "Sitio web oficial de nuestra institución tecnológica." } = Astro.props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/fvicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{titulo} | Instituto Superior</title>
	</head>
	
	<body class="bg-institucional-fondo text-slate-100 min-h-screen flex flex-col antialiased">
		
		<Navbar client:load />

		<main class="flex-grow">
			<slot /> 
		</main>

		<footer class="border-t border-institucional-componente bg-institucional-superficie/30 py-6 text-center text-sm text-slate-500">
			<p>&copy; {new Date().getFullYear()} Instituto Superior Tecnológico. Construido con Astro + React.</p>
		</footer>

	</body>
</html>