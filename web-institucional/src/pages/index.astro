---
//Importamos el componente de React
import BotonProps from "../components/botonprueba";
import "../styles/global.css";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Prueba Inicial - Web Institucional</title>
	</head>
	<body class="bg-slate-900 min-h-screen flex flex-col items-center justify-center font-sans p-4">
		
		<main class="text-center max-w-md w-full space-y-6">
			<h1 class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400 tracking-tight">
				Proyecto Institucional
			</h1>
			<p class="text-slate-400 text-sm">
				Astro + React + Tailwind + TypeScript funcionando correctamente.
			</p>

			<BotonProps client:load texto="¡Hacer Clic!" />
		</main>

	</body>
</html>